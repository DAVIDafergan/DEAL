# ===========================================================================
# Deal Radar Pro — דוגמת קובץ סביבה. העתיקו ל-.env ומלאו את הערכים הרלוונטיים.
# Copy this file to .env and fill in the values you have.
# ===========================================================================

# --- שרת / Server ---
PORT=3001

# --- Amadeus Self-Service API (flight search, free tier) ---
# קבלו מפתחות ב: https://developers.amadeus.com -> My Self-Service Workspace
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# --- Travelpayouts Flight Data API (Aviasales) ---
# קבלו טוקן ב: https://www.travelpayouts.com -> Tools -> API access (Partner API token)
TRAVELPAYOUTS_API_TOKEN=
# ה-Marker ID שלכם מתוכנית השותפים של Travelpayouts — חובה, כדי שלינקי הרכישה שמוחזרים
# יזכו אתכם בעמלת אפיליאייט. נמצא ב: https://www.travelpayouts.com -> Tools -> "Marker"
TRAVELPAYOUTS_MARKER=

# --- מסלולים לסריקה / Routes to scan ---
# פורמט: "ORIGIN-DEST,ORIGIN-DEST" (קודי IATA). אם משאירים ריק, הקוד (server/index.js) נופל
# אוטומטית לרשימת ברירת מחדל של כ-40 יעדים פופולריים מ-TLV (אירופה, נופש, מזרח רחוק) —
# כלומר הסריקה תתחיל "out of the box" גם בלי להגדיר את המשתנה הזה בכלל.
# If left empty, server/index.js falls back to a built-in default of ~40 popular TLV routes.
WATCHED_ROUTES=
# כל כמה דקות לסרוק מחדש. ⚠️ כל מסלול עושה 2 קריאות API (one-way + round-trip enrichment
# ל-"Best Live Prices") — עם ~40 מסלולים, כל 15 דק' זה ~320 קריאות/שעה ל-Travelpayouts. אם
# המכסה שלכם נמוכה (tier חינמי), עלו את המספר הזה אם אתם נתקלים ב-429 תכופים.
SCAN_INTERVAL_MINUTES=15
# כמה ימים קדימה לבדוק תאריך טיסה (יחיד, לפשטות בשלב זה)
SCAN_DATE_OFFSET_DAYS=30
# הנחת אורך חופשה (בימים) לחיפוש הלוך-חזור ב-"Best Live Prices" — תצוגה בלבד, לא נתון אמיתי
# מהמשתמש (אין תאריך חזרה אמיתי בסריקה האוטומטית, רק בשאלון האישי).
SCAN_RETURN_TRIP_DAYS=7
# השהיה (במילישניות) בין מסלול למסלול בתוך סריקה אחת — מגן מפני חציית מכסת rate-limit
# של מקורות כמו Travelpayouts כשסורקים רשימת מסלולים גדולה (כ-40 קריאות ברצף).
SCAN_REQUEST_DELAY_MS=1500
# כל כמה דקות לרענן את ה-vibe feed (/, ראו server/index.js). ~32 קריאות Travelpayouts
# לכל סבב (4 ווייבים × 8 יעדים) — בנוסף לסריקת המסלולים מעלה. 30 דק' זה ~64 קריאות/שעה נוספות.
VIBE_FEED_INTERVAL_MINUTES=30

# --- תמונת יעד אמיתית לכל כרטיס טיסה (גם ב-/ וגם ב-/feed) ---
# סדר עדיפות: PEXELS_API_KEY (להלן, בסקציית Vibe Feed) ראשון אם מוגדר, ואז UNSPLASH_ACCESS_KEY
# כ-fallback. שניהם אופציונליים ועצמאיים — אפשר להגדיר רק אחד מהם. קבלו Access Key ב:
# https://unsplash.com/developers (Create an app -> Demo tier מספיק, 50 בקשות/שעה — מספיק
# כי התמונות נשמרות ב-cache ב-MySQL וכל יעד נמשך פעם אחת ל-30 יום).
# בלי שום מפתח (לא Pexels ולא Unsplash), הכרטיסים פשוט יציגו gradient placeholder — לא קורס.
UNSPLASH_ACCESS_KEY=

# --- Travelpayouts: מלון/רכב/eSIM ("בנה חבילה") ---
# לינק המלונות (Hotellook) בנוי-בקוד ועובד מיד עם ה-Marker שלכם — אין צורך בהגדרה נוספת.
# לינקי רכב/eSIM משתנים בין חשבונות Travelpayouts — קחו את הפורמט המדויק מהדשבורד שלכם
# (Tools -> Car rental / eSIM -> Get link) והציבו אותו כתבנית כאן עם placeholders:
# {marker}, {destination} (קוד IATA), {checkin} (YYYY-MM-DD). בלי תבנית, הכפתור המתאים
# פשוט לא יוצג (לא שובר, לא ממציא לינק).
TRAVELPAYOUTS_CAR_RENTAL_URL_TEMPLATE=
TRAVELPAYOUTS_ESIM_URL_TEMPLATE=

# --- Vibe Feed (/feed) media — וידאו+מוזיקה רקע, כולם אופציונליים ---
# בלי שום מפתח כאן: הפיד עובד מלא (טיסה+מלון אמיתיים, מחיר אמיתי) עם gradient+motion CSS
# במקום וידאו, ובלי מוזיקת רקע — שום קישור לא ממציא. אם תוסיפו מפתחות, ה-resolver
# (media/videoResolver.js, media/musicResolver.js) מפעיל אותם אוטומטית, בלי שינוי קוד.
#
# Runway ML — וידאו AI-generated, יוקרתי אבל בתשלום (~$0.05-0.15/וידאו). ⚠️ לא מאומת מול
# תשובת API אמיתית — אין מפתח Production לבדוק.
RUNWAY_API_KEY=
# Pexels — fallback חינמי: וידאו אמיתי וקיים של היעד (לא AI). https://www.pexels.com/api
PEXELS_API_KEY=
# Pixabay Music API — מוזיקת רקע חינמית ברילס. קבלו מפתח ב: https://pixabay.com/service/about/api/
PIXABAY_API_KEY=
# Mubert — מוזיקת רקע AI מתאימה לווייב, בתשלום (זול). ⚠️ לא מאומת מול תשובת API אמיתית.
MUBERT_API_KEY=
# Cloud storage ל-media שנוצר ע"י Runway/Mubert (לא חוזרים ויוצרים בכל בקשה) — אופציונלי,
# לא מיושם בפועל עדיין (media/cloudStorage.js הוא stub שקוף עד שתאשרו איזה provider).
AWS_S3_BUCKET=
# CLOUDINARY_URL — גם הפורמט הרגיל שקלאודינרי חושף (cloudinary://<api_key>:<api_secret>@<cloud_name>).
# חובה כדי שהעלאת תמונות בטופס הנכס (7.4, POST /api/uploads/property-image) תעבוד בפועל — בלעדיו
# ה-endpoint מחזיר 503 בצורה מבוקרת (media/cloudinaryUpload.js). קבלו ב: https://cloudinary.com/console
CLOUDINARY_URL=

# --- Claude API (Anthropic) — לכתיבת נרטיב הדיל בשלוש שפות ---
# קבלו מפתח ב: https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Telegram Bot API ---
# צרו בוט עם @BotFather וקבלו טוקן. כל ערוץ הוא chat_id (למשל "@my_channel" או מזהה מספרי).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_HE=
TELEGRAM_CHANNEL_EN=
TELEGRAM_CHANNEL_ES=
# אופציונלי: ערוץ יחיד במקום שלושה (אם לא רוצים ערוץ נפרד לכל שפה)
TELEGRAM_CHANNEL_DEFAULT=

# --- WhatsApp Business Cloud API (Meta) ---
# הגדרת אפליקציה: https://developers.facebook.com/docs/whatsapp/cloud-api
# התבנית (template) חייבת להיות מאושרת מראש ב-Meta Business Manager.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=deal_alert
# רשימת נמענים מופרדת בפסיקים, בפורמט בינלאומי, לדוגמה: 972501234567,972529876543
WHATSAPP_RECIPIENTS=

# --- הודעות תאימות לבעלי נכסים (server/services/complianceMessaging.js) ---
# כברירת מחדל כבוי: כל הודעה נרשמת ללוג בלבד ולא נשלחת בפועל. אין להפעיל (true) לפני שנוסחי
# ההודעות (engine/templates/messages.he.md) קיבלו אישור עורך דין.
PROPERTY_MESSAGING_ENABLED=false
SUPPORT_EMAIL=support@dealim.org

# --- אימייל טרנזקציונלי (server/services/emailService.js) — Step 7.5 ---
# לא כפוף ל-PROPERTY_MESSAGING_ENABLED: אישורי הזמנה ללקוח, והתראות הזמנה חדשה לבעל נכס רשום
# (claimed/active), הן תקשורת טרנזקציונלית למשתמש שביקש אותה — לא הודעות שיווקיות לטלפון
# שנאסף. בלי RESEND_API_KEY, כל שליחה רק נרשמת ללוג. קבלו מפתח ב: https://resend.com
RESEND_API_KEY=
EMAIL_FROM=Dealim <noreply@dealim.org>

# --- מסד נתונים / MySQL ---
# הטבלאות (price_history, deals, deals_sent) נוצרות אוטומטית בהפעלה אם הן לא קיימות.
# Tables (price_history, deals, deals_sent) are created automatically on startup if missing.
#
# אופציה א' — connection string מלא (כך Railway חושף בד"כ MySQL מחובר):
# Option A — full connection string (this is how Railway usually exposes a linked MySQL service):
MYSQL_URL=
# אם אין MYSQL_URL, גם DATABASE_URL מתקבל (שם נפוץ בפלטפורמות אחרות):
DATABASE_URL=
#
# אופציה ב' — משתנים נפרדים (גם אלה נחשפים אוטומטית ע"י Railway בלשונית Variables של ה-MySQL
# service; אם MYSQL_URL/DATABASE_URL מוגדרים הם מקבלים עדיפות):
# Option B — discrete vars (also auto-exposed by Railway's MySQL service Variables tab;
# ignored if MYSQL_URL/DATABASE_URL is set):
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=

# --- Frontend (web/.env) ---
# כתובת בסיס ל-API שה-frontend פונה אליה (ריק = שימוש ב-proxy של Vite ל-localhost:3001)
VITE_API_BASE_URL=


# --- Admin Panel ---
# שם משתמש וסיסמה לכניסה לפאנל הניהול (/admin) — חובה לשנות בפרודקשן!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# --- Google OAuth (כניסה עם Google לסוכנים) ---
# צרו פרויקט ב: https://console.cloud.google.com → APIs & Services → Credentials
# צרו OAuth 2.0 Client ID מסוג "Web application"
# Authorized JavaScript origins: https://your-app.railway.app
# GOOGLE_CLIENT_ID + VITE_GOOGLE_CLIENT_ID = אותו Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=
