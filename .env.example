# ===========================================================================
# Deal Radar Pro — דוגמת קובץ סביבה. העתיקו ל-.env ומלאו את הערכים הרלוונטיים.
# Copy this file to .env and fill in the values you have.
# ===========================================================================

# --- שרת / Server ---
PORT=3001

# --- Amadeus Self-Service API (flight search, free tier) ---
# קבלו מפתחות ב: https://developers.amadeus.com -> My Self-Service Workspace
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# --- מסלולים לסריקה / Routes to scan ---
# פורמט: "ORIGIN-DEST,ORIGIN-DEST" (קודי IATA), לדוגמה:
WATCHED_ROUTES=TLV-BCN,TLV-FCO,TLV-BKK
# כל כמה דקות לסרוק מחדש
SCAN_INTERVAL_MINUTES=60
# כמה ימים קדימה לבדוק תאריך טיסה (יחיד, לפשטות בשלב זה)
SCAN_DATE_OFFSET_DAYS=30

# --- Claude API (Anthropic) — לכתיבת נרטיב הדיל בשלוש שפות ---
# קבלו מפתח ב: https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Telegram Bot API ---
# צרו בוט עם @BotFather וקבלו טוקן. כל ערוץ הוא chat_id (למשל "@my_channel" או מזהה מספרי).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_HE=
TELEGRAM_CHANNEL_EN=
TELEGRAM_CHANNEL_ES=
# אופציונלי: ערוץ יחיד במקום שלושה (אם לא רוצים ערוץ נפרד לכל שפה)
TELEGRAM_CHANNEL_DEFAULT=

# --- WhatsApp Business Cloud API (Meta) ---
# הגדרת אפליקציה: https://developers.facebook.com/docs/whatsapp/cloud-api
# התבנית (template) חייבת להיות מאושרת מראש ב-Meta Business Manager.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=deal_alert
# רשימת נמענים מופרדת בפסיקים, בפורמט בינלאומי, לדוגמה: 972501234567,972529876543
WHATSAPP_RECIPIENTS=

# --- מסד נתונים / SQLite ---
# נתיב יחסי לקובץ ה-SQLite להיסטוריית מחירים (ייווצר אוטומטית אם לא קיים)
SQLITE_DB_PATH=./data/price-history.sqlite

# --- Frontend (web/.env) ---
# כתובת בסיס ל-API שה-frontend פונה אליה (ריק = שימוש ב-proxy של Vite ל-localhost:3001)
VITE_API_BASE_URL=
